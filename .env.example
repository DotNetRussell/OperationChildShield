# Get your free API key at https://api.congress.gov/sign-up/
CONGRESS_API_KEY=

# Current Congress session (119th = Jan 2025 - Jan 2027)
CONGRESS_NUMBER=119

# How long to cache Congress.gov responses (seconds). Default: 86400 (24 hours)
CACHE_TTL_SECONDS=86400

# Comma-separated origins allowed by the backend CORS middleware
CORS_ORIGINS=http://localhost:3000

# Frontend (local dev)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Canonical public site URL (Open Graph / social sharing)
NEXT_PUBLIC_SITE_URL=https://operationchildshield.org